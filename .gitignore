# =============================================================
# The Teacher's Desk — root .gitignore
# Single source of truth; tools shouldn't ship their own.
# =============================================================

# --- Node / npm ---
node_modules/
dist/
dist-ssr/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- TypeScript / Vite build artifacts ---
*.tsbuildinfo
seating-chart/vite.config.d.ts
seating-chart/vite.config.js

# --- Environment files ---
.env
.env.*
!.env.example
*.local

# --- VS Code ---
# Keep the shared workspace config, ignore per-user state.
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json

# --- Other editors / IDEs ---
.idea/
*.swp
*.swo
*~

# --- OS cruft ---
.DS_Store
Thumbs.db
desktop.ini

# --- Claude Code per-machine config ---
.claude/

# --- Personal notes / scratch files ---
To-Dos.txt
TODO.txt
NOTES.md
notes.md

# --- Misc / unrelated work kept locally ---
lego-analysis/
